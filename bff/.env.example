# Cyera Vantage BFF — environment (LIVE mode). Copy to .env for local live runs;
# in production these come from Kubernetes secrets/config in cyera-flux.
# In demo mode (DATA_MODE unset or "demo") NONE of the Snowflake vars are needed.

# --- Mode --------------------------------------------------------------------
DATA_MODE=live                 # "live" = real proxy-auth + Snowflake; unset = demo scaffold

# --- Auth (access proxy) -----------------------------------------------------
# The header the Cyera access proxy injects with the authenticated user's email.
# UNKNOWN — CONFIRM WITH PLATFORM/IT before go-live. Common defaults:
#   oauth2-proxy      -> x-auth-request-email
#   Okta Access Gwy   -> (varies; ask)
IDENTITY_HEADER=x-auth-request-email

# --- CORS --------------------------------------------------------------------
ALLOWED_ORIGIN=https://<vantage-dashboard-host>

# --- Snowflake (BFF's OWN service account — NOT the Claude Code account) ------
# Platform must provision a dedicated read-only service user scoped to the
# tables this BFF reads (CS__CUSTOMER_RISK, PRODUCT__TENANT_ISSUE_METRICS).
SNOWFLAKE_ACCOUNT=tdb04658.us-east-1
SNOWFLAKE_USERNAME=<vantage_bff_service_user>
SNOWFLAKE_PASSWORD=<from-k8s-secret>
SNOWFLAKE_ROLE=<vantage_bff_readonly_role>
SNOWFLAKE_WAREHOUSE=<xs_warehouse>
SNOWFLAKE_DATABASE=CYERA_BI_DBT_PROD
